{
  "name": "pi-deck",
  "version": "0.1.0",
  "private": true,
  "description": "Local macOS Electron GUI control plane for Pi agents.",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist/main/main.js\"",
    "deck": "node scripts/start-pi-deck.mjs",
    "deck:fake": "node scripts/start-pi-deck.mjs --fake --launch",
    "deck:real": "node scripts/start-pi-deck.mjs --real --launch",
    "deck:fake:build": "node scripts/start-pi-deck.mjs --fake --launch --build",
    "deck:real:build": "node scripts/start-pi-deck.mjs --real --launch --build",
    "dev:real": "node scripts/start-pi-deck.mjs --real --dev",
    "launch": "node scripts/launch-built.mjs",
    "launch:build": "npm run build && npm run launch",
    "launch:real": "node scripts/start-pi-deck.mjs --real --launch",
    "start": "npm run deck:real",
    "build": "npm run build:main && npm run build:renderer && node scripts/write-build-manifest.mjs",
    "build:main": "tsc -p tsconfig.main.json && esbuild src/preload/index.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload/index.js --sourcemap",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test -c e2e/playwright.config.ts",
    "test:e2e:headed": "PI_DECK_E2E_HIDE_WINDOWS=0 npm run test:e2e",
    "test:e2e:real-smoke": "npm run build && PI_DECK_E2E_REAL_SMOKE=1 playwright test -c e2e/playwright.config.ts e2e/real-pi-smoke.e2e.ts",
    "smoke:real": "node scripts/smoke-real-pi.mjs",
    "smoke:real:prompt": "node scripts/smoke-real-pi.mjs --prompt \"Reply with exactly: PI_DECK_REAL_SMOKE_OK\"",
    "lint": "npm run typecheck",
    "format": "prettier --check \"index.html\" \"package*.json\" \"*.config.ts\" \"tsconfig*.json\" \"scripts/**/*.mjs\" \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\""
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "electron": "42.5.0",
    "esbuild": "0.28.1",
    "jsdom": "^29.1.1",
    "prettier": "3.8.5",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "wait-on": "9.0.10"
  }
}
