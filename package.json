{
  "name": "pi-deck",
  "version": "0.1.0",
  "private": true,
  "description": "Local macOS Electron GUI control plane for Pi agents.",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist/main/main.js\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json && esbuild src/preload/index.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload/index.js --sourcemap",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "vitest run",
    "lint": "npm run typecheck",
    "format": "prettier --check \"index.html\" \"package*.json\" \"*.config.ts\" \"tsconfig*.json\" \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "electron": "42.5.0",
    "esbuild": "0.28.1",
    "prettier": "3.8.5",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "wait-on": "9.0.10"
  }
}
